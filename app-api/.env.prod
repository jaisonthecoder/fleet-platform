# Production environment (dummy values — real values injected from Key Vault via
# managed identity in the pipeline; this file documents the required keys only).
NODE_ENV=production
DATA_REGION=uae-north
ORGANIZATION_ID=00000000-0000-0000-0000-000000000ad0

API_PORT=3000
API_GLOBAL_PREFIX=api
CORS_ORIGINS=https://fleet.adports.example

PDP_PORT=3001
PDP_URL=http://fleet-prod-pdp.internal:3001
PDP_LATENCY_BUDGET_MS=200
ELIGIBILITY_LATENCY_BUDGET_MS=500

LOG_LEVEL=info
LOG_PRETTY=false

DATABASE_URL=postgres://fleet_prod:FROM_KEY_VAULT@fleet-prod-psql.postgres.database.azure.com:5432/fleet?sslmode=require
DATABASE_SSL=true
DATABASE_MAX_CONNECTIONS=40

REDIS_URL=rediss://fleet-prod-redis.redis.cache.windows.net:6380
REDIS_TLS=true

SERVICE_BUS_CONNECTION_STRING=FROM_KEY_VAULT
SERVICE_BUS_TOPIC=domain-events

EVENT_HUBS_CONNECTION_STRING=FROM_KEY_VAULT
EVENT_HUB_NAME=telemetry
EVENT_HUBS_CONSUMER_GROUP=ingest

STORAGE_CONNECTION_STRING=FROM_KEY_VAULT
STORAGE_CONTAINER_DOCUMENTS=vehicle-docs
STORAGE_CONTAINER_CONSENT=consent-records
STORAGE_CONTAINER_CHECKPOINTS=eventhub-checkpoints

ENTRA_TENANT_ID=44444444-4444-4444-4444-444444444444
ENTRA_API_CLIENT_ID=55555555-5555-5555-5555-555555555555
ENTRA_API_AUDIENCE=api://fleet
ENTRA_ISSUER=https://login.microsoftonline.com/44444444-4444-4444-4444-444444444444/v2.0

KEY_VAULT_URI=https://fleet-prod-kv.vault.azure.net/
AZURE_MAPS_CLIENT_ID=66666666-6666-6666-6666-666666666666
AZURE_MAPS_KEY=FROM_KEY_VAULT

OTEL_ENABLED=true
OTEL_SERVICE_NAME=fleet-api
APPLICATIONINSIGHTS_CONNECTION_STRING=FROM_KEY_VAULT

TELEMETRY_SOURCE=aggregator
SIMULATOR_INTERVAL_MS=30000
SIMULATOR_DEVICE_COUNT=50

SWAGGER_ENABLED=false
SWAGGER_PATH=api-docs

# Dev-login stand-in disabled (structurally forced off here regardless; explicit for clarity, P0-R2-4)
AUTH_DEV_LOGIN=false
