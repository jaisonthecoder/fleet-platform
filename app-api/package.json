{
  "name": "fleet-platform-api",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11.15.0"
  },
  "scripts": {
    "build": "swc src --out-dir dist --strip-leading-paths --config-file .swcrc --ignore **/*.spec.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "pnpm start:api",
    "start:api": "pnpm build && node --enable-source-maps dist/main.js",
    "start:pdp": "pnpm build && node --enable-source-maps dist/main.pdp.js",
    "start:ingest": "pnpm build && node --enable-source-maps dist/main.ingest.js",
    "start:dev": "pnpm build && node --watch --enable-source-maps dist/main.js",
    "lint": "oxlint src test",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "guard:org": "node scripts/guard-organization-id.mjs",
    "guard:contracts": "node scripts/contracts-drift.mjs",
    "guard:contracts:update": "node scripts/contracts-drift.mjs --update",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "psql \"$DATABASE_URL\" -f scripts/seed-dev.sql",
    "migration:test": "node scripts/migration-test.mjs",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:integration": "jest --config ./test/jest-integration.json --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/event-hubs": "catalog:",
    "@azure/eventhubs-checkpointstore-blob": "catalog:",
    "@azure/monitor-opentelemetry-exporter": "catalog:",
    "@azure/service-bus": "catalog:",
    "@azure/storage-blob": "catalog:",
    "@fastify/helmet": "catalog:",
    "@fastify/static": "^8.0.0",
    "@nestjs/bullmq": "catalog:",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "catalog:",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/swagger": "catalog:",
    "@nestjs/terminus": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/auto-instrumentations-node": "catalog:",
    "@opentelemetry/sdk-node": "catalog:",
    "bullmq": "catalog:",
    "drizzle-orm": "catalog:",
    "fastify": "^5.10.0",
    "ioredis": "catalog:",
    "jose": "catalog:",
    "nestjs-pino": "catalog:",
    "nestjs-zod": "catalog:",
    "pino": "catalog:",
    "pino-http": "catalog:",
    "piscina": "catalog:",
    "postgres": "catalog:",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "chokidar": "^5.0.0",
    "dependency-cruiser": "catalog:",
    "dotenv": "catalog:",
    "drizzle-kit": "catalog:",
    "jest": "^30.4.2",
    "oxlint": "^1.74.0",
    "pino-pretty": "catalog:",
    "prettier": "^3.9.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^7.0.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "@swc/jest",
        {
          "jsc": {
            "parser": {
              "syntax": "typescript",
              "decorators": true
            },
            "transform": {
              "legacyDecorator": true,
              "decoratorMetadata": true
            },
            "target": "es2023"
          },
          "module": {
            "type": "commonjs"
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "/node_modules/\\.pnpm/(?!jose@)"
    ]
  }
}
