# Template of all supported environment variables.
# Copy to `.env.local` for personal overrides (`.env.local` is git-ignored).
#
# IMPORTANT: every VITE_* variable is bundled into the client and is PUBLIC.
# Do NOT store secrets here — secrets belong in the backend / Key Vault only.

# Environment name: development | ut | production
VITE_APP_ENV=development

# Display name for the application shell.
VITE_APP_NAME=Carpool & Fleet Platform

# Base URL for API calls. The SPA calls the backend DIRECTLY cross-origin (no
# proxy); set the full versioned base. The backend must allow this origin via
# CORS (app-api CORS_ORIGINS). Falls back to VITE_API_BASE_URL, then "/api".
VITE_API_URL=http://localhost:3000/api/v1

# ── Auth ─────────────────────────────────────────────────────────────
# Dev-login stand-in (header x-dev-person-id). 'false' disables it; it is never
# offered in production regardless. (Legacy alias: VITE_AUTH_DEV_LOGIN.)
VITE_DEV_LOGIN=true

# Microsoft Entra / Azure AD SSO (public values — client/tenant ids are not
# secrets). When client + tenant are set, the SSO button is enabled and MSAL is
# initialised. Preferred VITE_AAD_* names (legacy VITE_ENTRA_* still accepted).
VITE_AAD_TENANT_ID=
VITE_AAD_CLIENT_ID=
# Optional explicit authority (else derived from the tenant id).
VITE_AAD_AUTHORITY=
# SPA redirect URI — must be registered on the app registration (SPA platform).
VITE_AAD_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_AAD_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/login
# API scope requested for the backend access token.
VITE_AAD_API_SCOPE=api://fleet-api/user_impersonation
