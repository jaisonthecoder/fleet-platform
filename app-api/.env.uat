# UAT environment (dummy values — replace with Key Vault-sourced secrets in CI/CD).
NODE_ENV=uat
DATA_REGION=uae-north
ORGANIZATION_ID=00000000-0000-0000-0000-000000000ad0

API_PORT=3000
API_GLOBAL_PREFIX=api
CORS_ORIGINS=https://fleet-uat.adports.example

PDP_PORT=3001
PDP_URL=http://fleet-uat-pdp.internal:3001
PDP_LATENCY_BUDGET_MS=200
ELIGIBILITY_LATENCY_BUDGET_MS=500

LOG_LEVEL=info
LOG_PRETTY=false

DATABASE_URL=postgres://fleet_uat:CHANGE_ME@fleet-uat-psql.postgres.database.azure.com:5432/fleet?sslmode=require
DATABASE_SSL=true
DATABASE_MAX_CONNECTIONS=20

REDIS_URL=rediss://fleet-uat-redis.redis.cache.windows.net:6380
REDIS_TLS=true

SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://fleet-uat.servicebus.windows.net/;SharedAccessKeyName=app;SharedAccessKey=CHANGE_ME
SERVICE_BUS_TOPIC=domain-events

EVENT_HUBS_CONNECTION_STRING=Endpoint=sb://fleet-uat-eh.servicebus.windows.net/;SharedAccessKeyName=ingest;SharedAccessKey=CHANGE_ME
EVENT_HUB_NAME=telemetry
EVENT_HUBS_CONSUMER_GROUP=ingest

STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=fleetuatsa;AccountKey=CHANGE_ME;EndpointSuffix=core.windows.net
STORAGE_CONTAINER_DOCUMENTS=vehicle-docs
STORAGE_CONTAINER_CONSENT=consent-records
STORAGE_CONTAINER_CHECKPOINTS=eventhub-checkpoints

ENTRA_TENANT_ID=11111111-1111-1111-1111-111111111111
ENTRA_API_CLIENT_ID=22222222-2222-2222-2222-222222222222
ENTRA_API_AUDIENCE=api://fleet-uat
ENTRA_ISSUER=https://login.microsoftonline.com/11111111-1111-1111-1111-111111111111/v2.0

KEY_VAULT_URI=https://fleet-uat-kv.vault.azure.net/
AZURE_MAPS_CLIENT_ID=33333333-3333-3333-3333-333333333333
AZURE_MAPS_KEY=CHANGE_ME

OTEL_ENABLED=true
OTEL_SERVICE_NAME=fleet-api-uat
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://uaenorth-0.in.applicationinsights.azure.com/

TELEMETRY_SOURCE=simulator
SIMULATOR_INTERVAL_MS=30000
SIMULATOR_DEVICE_COUNT=50

SWAGGER_ENABLED=true
SWAGGER_PATH=api-docs

# Dev-login stand-in disabled (structurally forced off here regardless; explicit for clarity, P0-R2-4)
AUTH_DEV_LOGIN=false
