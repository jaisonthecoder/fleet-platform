# Production (loaded automatically by `pnpm build`).
VITE_APP_ENV=production
VITE_API_BASE_URL=https://fleet.adports.example/api

# Auth: SSO only in production (dev-login is structurally disabled). Entra values
# are injected by the deployment pipeline (client id + tenant id are public).
VITE_AUTH_DEV_LOGIN=false
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_API_SCOPE=
