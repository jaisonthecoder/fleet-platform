# ─────────────────────────────────────────────────────────────────────────────
# Fleet Management Platform — API environment template (committed reference).
# Copy to .env.local for local development. Never commit real secrets.
# Precedence: .env.<NODE_ENV> > .env.local > .env
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=local
DATA_REGION=uae-north
# Dormant multi-org seam (ADR-008): inert default, never branched on in code.
ORGANIZATION_ID=00000000-0000-0000-0000-000000000ad0

# API deployable
API_PORT=3000
API_GLOBAL_PREFIX=api
CORS_ORIGINS=http://localhost:5173

# PDP deployable + latency budgets (ms)
PDP_PORT=3001
PDP_URL=http://localhost:3001
PDP_LATENCY_BUDGET_MS=200
ELIGIBILITY_LATENCY_BUDGET_MS=500

# Logging
LOG_LEVEL=info
LOG_PRETTY=false

# PostgreSQL + TimescaleDB
DATABASE_URL=postgres://fleet:fleet@localhost:5432/fleet
DATABASE_SSL=false
DATABASE_MAX_CONNECTIONS=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# Azure Service Bus (domain events)
SERVICE_BUS_CONNECTION_STRING=
SERVICE_BUS_TOPIC=domain-events

# Azure Event Hubs (telemetry ingress)
EVENT_HUBS_CONNECTION_STRING=
EVENT_HUB_NAME=telemetry
EVENT_HUBS_CONSUMER_GROUP=ingest

# Azure Blob Storage
STORAGE_CONNECTION_STRING=
STORAGE_CONTAINER_DOCUMENTS=vehicle-docs
STORAGE_CONTAINER_CONSENT=consent-records
STORAGE_CONTAINER_CHECKPOINTS=eventhub-checkpoints

# Microsoft Entra ID (OIDC/JWT)
ENTRA_TENANT_ID=
ENTRA_API_CLIENT_ID=
ENTRA_API_AUDIENCE=
ENTRA_ISSUER=

# Dev-login stand-in (P0-R2-4). Enables the GET /me `?personId=` stand-in in
# lower environments only. Structurally forced OFF in uat/production regardless
# of this value — do not rely on it there.
AUTH_DEV_LOGIN=true

# Azure Key Vault + Azure Maps
KEY_VAULT_URI=
AZURE_MAPS_CLIENT_ID=
AZURE_MAPS_KEY=

# Observability (OpenTelemetry -> Application Insights)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=fleet-api
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Telematics ingest
TELEMETRY_SOURCE=simulator
SIMULATOR_INTERVAL_MS=30000
SIMULATOR_DEVICE_COUNT=50

# OpenAPI / Swagger (served in non-production)
SWAGGER_ENABLED=true
SWAGGER_PATH=api-docs